DATABASE_URL="postgresql://user:password@localhost:5432/tvv_travel_os?schema=public"

# Auth module (see src/modules/auth/services/auth-config.service.ts) — all have
# insecure local defaults if unset; override every one of these before any
# non-local deployment.
AUTH_JWT_SECRET=""
AUTH_ACCESS_TOKEN_TTL_SECONDS=""
AUTH_REFRESH_TOKEN_TTL_SECONDS=""
AUTH_REFRESH_TOKEN_REMEMBER_ME_TTL_SECONDS=""
AUTH_PASSWORD_RESET_TTL_SECONDS=""
AUTH_MAX_FAILED_LOGIN_ATTEMPTS=""
AUTH_ACCOUNT_LOCK_DURATION_SECONDS=""

# CORS (see src/shared/cors/cors-config.service.ts) — comma-separated exact
# origins allowed to call this API from a browser. Defaults to the local
# Website frontend dev port only. Add the real production frontend
# origin(s) here before deploying, e.g.:
#   CORS_ALLOWED_ORIGINS="http://localhost:3001,https://www.thevacationvoice.com"
# Never "*" — see cors-config.service.ts's docstring for why.
CORS_ALLOWED_ORIGINS="http://localhost:3001"

# ── Razorpay Payment Gateway ───────────────────────────────────────────────
# RAZORPAY_KEY_ID and RAZORPAY_KEY_SECRET are the Razorpay API credentials.
# Use rzp_test_* keys for UAT/staging and rzp_live_* keys for production.
# RAZORPAY_WEBHOOK_SECRET is set in the Razorpay Dashboard → Webhooks → Secret.
# THIS IS CRITICAL: without it the webhook endpoint will refuse all events.
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# ── TripJack Supplier API ──────────────────────────────────────────────────
# Use https://apitest.tripjack.com for UAT, https://api.tripjack.com for production.
# TRIPJACK_TOKEN is the static API key issued by TripJack (preferred).
# If no token, set TRIPJACK_AGENCY_ID + TRIPJACK_USER_ID + TRIPJACK_PASSWORD
# for the login-exchange flow.
TRIPJACK_ENABLED=true
TRIPJACK_API_URL="https://apitest.tripjack.com"
TRIPJACK_AGENCY_ID=""
TRIPJACK_USER_ID=""
TRIPJACK_TOKEN=""
TRIPJACK_EMAIL=""
TRIPJACK_PASSWORD=""

# ── OpenAI (AI Itinerary Generator) ───────────────────────────────────────
OPENAI_API_KEY=""

# ── Email (SMTP) ───────────────────────────────────────────────────────────
# If not set, booking confirmation emails are logged to console (no actual send).
# Supports any SMTP provider: Gmail, Mailgun, AWS SES, etc.
SMTP_HOST=""
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="\"TVV Travel OS\" <noreply@thevacationvoice.com>"

# ── Redis (BullMQ Job Queue) ───────────────────────────────────────────────
# Optional. If not set, booking fulfillment jobs run synchronously (no queue).
# For production with high volume, set this to a Redis instance URL.
# Format: redis://[:password@]host[:port][/db-number]
REDIS_URL=""
