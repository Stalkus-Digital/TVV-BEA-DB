# Copy to .env.local for local dev
# 1) Start Travel OS backend (default http://localhost:3000)
# 2) Start site: npm run dev → http://localhost:3001

# Travel OS API base (scheme + host only — paths are /api/...)
NEXT_PUBLIC_TRAVEL_OS_API_URL=http://localhost:3000

# Legacy alias — still read if TRAVEL_OS_API_URL is unset
# NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# Set true for offline UI work without Travel OS; defaults to false (live API).
NEXT_PUBLIC_USE_MOCK=false

# Optional overrides
# NEXT_PUBLIC_API_TIMEOUT_MS=12000
# NEXT_PUBLIC_API_RETRIES=1

# Optional Postgres hierarchy — put in .env.local only (NOT committed)
# HIERARCHY_DATABASE_URL=postgresql://USER@localhost:5432/tvv_hierarchy?schema=public
