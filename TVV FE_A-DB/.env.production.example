# Production on DigitalOcean — copy to .env.production before: npm run build
# The marketing site MUST use the public API URL (HTTPS), not localhost.

NEXT_PUBLIC_API_BASE_URL=https://api.thevacationvoice.com/api
NEXT_PUBLIC_USE_MOCK=false

# Optional — only if you use Postgres destination hierarchy routes
# HIERARCHY_DATABASE_URL=postgresql://USER:PASS@127.0.0.1:5432/tvv_hierarchy?schema=public
