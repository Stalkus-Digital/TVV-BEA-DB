{
  "name": "the-vacation-voice",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "./node_modules/.bin/next dev",
    "build": "./node_modules/.bin/next build",
    "start": "./node_modules/.bin/next start",
    "test": "./node_modules/.bin/vitest run --config vitest.config.ts",
    "test:watch": "./node_modules/.bin/vitest --config vitest.config.ts",
    "test:coverage": "./node_modules/.bin/vitest run --config vitest.config.ts --coverage",
    "test:integration": "npm run build && ./node_modules/.bin/vitest run --config vitest.integration.config.ts",
    "test:e2e": "./node_modules/.bin/playwright test",
    "test:all": "npm run test && npm run test:integration && npm run test:e2e",
    "db:seed": "./node_modules/.bin/prisma db seed"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@vercel/blob": "^2.5.0",
    "lightningcss-darwin-arm64": "^1.32.0",
    "lucide-react": "^1.12.0",
    "next": "^15.1.6",
    "pg": "^8.22.0",
    "prisma": "^7.8.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "latest",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.9",
    "dotenv": "^17.4.2",
    "msw": "^2.14.6",
    "postcss": "^8",
    "supertest": "^7.2.2",
    "tailwindcss": "latest",
    "tsx": "^4.22.5",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
